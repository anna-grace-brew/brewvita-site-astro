---
import MessagesWidget from "../components/MessagesWidget.astro";
import Navbar from "../components/Navbar.astro";
import TestimonialCard from "../components/TestimonialCard.astro";
import Footer from "../components/Footer.astro";

type Testimonial = {
    name: string;
    quote: string;
    detailOne: string;
    detailTwo?: string;
    detailThree: string;
    image: string;
    rotation: string;
    imageCrop?: "face";
};

const testimonials: Testimonial[] = [
    {
        name: "Samuel Falker",
        quote: "I love the brew crew. Each one of them knows me by name and the usual for each creative menu. It’s been a sweet experience in every sense.",
        detailOne: "Major: Theatre Arts",
        detailTwo: "Year: Junior",
        detailThree: "Favorite drink: French Toast - maple latte with brown sugar foam and cinnamon powder",
        image: "/testimonial-samuel.png",
        rotation: "-rotate-2",
    },
    {
        name: "Corrianna Cossette",
        quote: "Brewvita is Liberty’s coolest spot. The coffee is absolutely delicious every single time, I’ve never had a coffee there I haven’t liked. Brewvita has my heart.",
        detailOne: "Major: Film Production & Content Development",
        detailTwo: "Year: Sophomore",
        detailThree: "Favorite drink: Palm Tree - blue lotus with pineapple and coconut",
        image: "/testimonial-corrianna.png",
        rotation: "rotate-1",
        imageCrop: "face",
    },
    {
        name: "Stuart Bennett",
        quote: "Since Brewvita first appeared in Tilly, I have become a regular customer. In addition, I love the fact that I am supporting students by giving them my business instead of other commercial vendors. Go Brewvita!",
        detailOne: "Professor of Cinematic Arts",
        detailTwo: "",
        detailThree: "Favorite drink: Hot whole milk latte with 2 splenda",
        image: "/testimonial-stuart.png",
        rotation: "-rotate-1",
    },
];
---
<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Brewvita Coffee Co. | Home</title>
        <link rel="icon" href="/favicon.ico" sizes="any" />
        <script src="https://cdn.tailwindcss.com" is:inline></script>
        <style is:global>
            @font-face {
                font-family: "Block Berthold Condensed";
                src: url("/Block_Berthold_Condensed.woff2") format("woff2");
                font-weight: 400 700;
                font-style: normal;
                font-display: swap;
            }
        </style>
        <link
            href="https://fonts.googleapis.com/css2?family=Alike&display=swap"
            rel="stylesheet"
        />
        <script is:inline>
            tailwind.config = {
                theme: {
                    extend: {
                        colors: {
                            ink: "#1f2327",
                            slate: "#2a3d52",
                            mist: "#b8cde6",
                            fog: "#d9e6f5",
                            navy: "#152433",
                            steel: "#2d4056",
                        },
                        fontFamily: {
                            sans: ['"Block Berthold Condensed"', "sans-serif"],
                            mono: ['"Alike"', "serif"],
                        },
                        boxShadow: {
                            hard: "4px 4px 0px 0px #152433",
                            "hard-hover": "1px 1px 0px 0px #152433",
                        },
                        animation: {
                            marquee: "marquee 25s linear infinite",
                        },
                        keyframes: {
                            marquee: {
                                "0%": { transform: "translateX(0%)" },
                                "100%": { transform: "translateX(-100%)" },
                            },
                        },
                    },
                },
            };
        </script>
        <style is:global>
            .border-hard {
                border: 3px solid #152433;
            }
            .text-stroke {
                -webkit-text-stroke: 1px #152433;
                color: transparent;
            }
            .testimonial-grid {
                perspective: 1800px;
            }
            @media (max-width: 767px) {
                .testimonial-card {
                    min-height: 25rem;
                }
            }
        </style>
    </head>
    <body
        class="bg-fog text-navy font-sans antialiased selection:bg-slate selection:text-white"
    >
        <Navbar />

        <!-- Hero -->
        <header
            class="relative h-[70vh] border-b-4 border-navy overflow-hidden group"
        >
            <!-- Video -->
            <video
                autoplay
                loop
                muted
                playsinline
                class="absolute inset-0 w-full h-full object-cover grayscale opacity-30 mix-blend-multiply"
            >
                <source
                    src="/hero-video.mp4"
                    type="video/mp4"
                />
            </video>
            <div
                class="relative z-10 h-full flex flex-col justify-center md:items-center px-6 md:px-12 max-w-7xl mx-auto pointer-events-none"
            >
                <h1
                    class="text-7xl md:text-9xl font-bold uppercase leading-[0.85] tracking-tight text-navy mix-blend-hard-light md:text-center md:whitespace-nowrap"
                >
                    Brewvita<span class="md:hidden"><br /></span> Coffee Co.
                </h1>
                <p
                    class="mt-4 font-bold text-base md:text-lg uppercase tracking-[0.2em] text-navy md:text-center"
                >
                    By Students, For Students.
                </p>
                <div class="mt-10 pointer-events-auto md:text-center">
                    <a
                        href="/order"
                        class="inline-block bg-mist text-navy border-hard rounded-full px-10 py-5 font-bold text-lg uppercase shadow-hard hover:translate-x-[3px] hover:translate-y-[3px] hover:shadow-hard-hover transition-all"
                    >
                        Order Online
                    </a>
                </div>
            </div>
        </header>

        <!-- Testimonials -->
        <section class="bg-white border-b-4 border-navy py-12 px-6">
            <div class="max-w-6xl mx-auto mb-8 text-center">
                <p class="font-mono text-xs uppercase tracking-[0.25em] text-slate">
                    Hover To Flip
                </p>
            </div>
            <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10 testimonial-grid">
                {
                    testimonials.map((testimonial) => (
                        <TestimonialCard
                            name={testimonial.name}
                            quote={testimonial.quote}
                            detailOne={testimonial.detailOne}
                            detailTwo={testimonial.detailTwo}
                            detailThree={testimonial.detailThree}
                            image={testimonial.image}
                            rotation={testimonial.rotation}
                            imageCrop={testimonial.imageCrop}
                        />
                    ))
                }
            </div>
        </section>

        <!-- Products & Info -->
        <section
            class="grid grid-cols-1 lg:grid-cols-12 lg:h-[600px] border-b-4 border-navy"
        >
            <!-- Products Left -->
            <div
                class="lg:col-span-5 bg-navy text-fog p-12 flex flex-col justify-center border-b-4 lg:border-b-0 lg:border-r-4 border-navy relative overflow-hidden"
            >
                <div>
                    <h2 class="text-5xl font-bold uppercase mb-8 leading-none">
                        Our Products
                    </h2>
                    <div class="space-y-6 font-mono text-lg">
                        <p class="opacity-80">
                            At Brewvita, every product is rooted in quality and purpose. From our Closed Coffee with meaningful origins to our specialty drinks, everything is crafted with care. We prioritize fresh roasted coffee for a vibrant flavor and offer plant-based energy drinks for a clean, steady boost.
                        </p>
                    </div>
                </div>

            </div>

            <!-- Photo Right -->
            <div
                class="lg:col-span-7 bg-white p-12 flex items-center justify-center border-b-4 lg:border-b-0 border-navy lg:h-full overflow-hidden"
            >
                <div class="bg-slate p-1 w-full h-full overflow-hidden">
                    <img
                        src="/IMG_1432.JPG"
                        alt="Brewvita"
                        class="w-full h-full object-cover object-bottom border-2 border-white"
                    />
                </div>
            </div>
        </section>

        <!-- What is Closed Coffee? -->
        <section
            class="grid grid-cols-1 md:grid-cols-2 border-b-4 border-navy bg-navy"
        >
            <div
                class="min-h-[26rem] md:min-h-[34rem] border-b-4 md:border-b-0 md:border-r-4 border-navy bg-navy overflow-hidden relative"
            >
                <img
                    src="/closed.webp"
                    alt="Closed Coffee bag stack"
                    class="w-full h-full object-cover"
                />
            </div>
            <div class="p-12 md:p-20 flex flex-col justify-center relative bg-navy text-fog">
                <h2
                    class="text-4xl md:text-5xl font-bold uppercase mb-8 text-fog"
                >
                <span class="text-transparent [-webkit-text-stroke:1px_#b8cde6]">What is</span>
                    Closed Coffee?
                </h2>

                <div class="font-mono text-sm leading-relaxed space-y-4 text-mist">
                    <p>
                        The X family grows coffee in a country closed to the Christianity. Every bag of Closed Coffee supports the mission of sharing the Gospel where Christ’s name cannot be preached. 
                    </p>
                    <p>
                        Buy Closed Coffee beans at the Montview Market, previously the Grid, located in Montview Student Union at Liberty University.
                    </p>
                </div>

            </div>
        </section>

        <!-- Get Involved / Footer Hero -->
        <section class="py-24 px-6 bg-fog relative overflow-hidden">
            <div class="max-w-4xl mx-auto text-center relative z-10">
                <h2
                    class="text-6xl md:text-8xl font-bold uppercase mb-8 text-navy tracking-tight"
                >
                    Get Involved
                </h2>
                <p class="font-mono text-lg max-w-2xl mx-auto mb-12">
                    We want to connect with you! Check out the opportunities for
                    you to get involved with Brewvita and join our community.
                </p>

                <div class="flex flex-wrap justify-center gap-4 mb-16">
                    <a
                        href="/application"
                        class="px-6 py-3 border-hard rounded-full bg-white hover:bg-navy hover:text-white transition-colors font-bold uppercase text-sm shadow-hard hover:shadow-hard-hover hover:translate-x-[3px] hover:translate-y-[3px]"
                        >Application</a
                    >
                    <a
                        href="/suggestion"
                        class="px-6 py-3 border-hard rounded-full bg-white hover:bg-navy hover:text-white transition-colors font-bold uppercase text-sm shadow-hard hover:shadow-hard-hover hover:translate-x-[3px] hover:translate-y-[3px]"
                        >Drink Suggestion</a
                    >
                    <a
                        href="https://groupme.com/join_group/109529495/AAfO8L3b"
                        class="px-6 py-3 border-hard rounded-full bg-white hover:bg-navy hover:text-white transition-colors font-bold uppercase text-sm shadow-hard hover:shadow-hard-hover hover:translate-x-[3px] hover:translate-y-[3px]"
                        >Join Enactus</a
                    >
                    <a
                        href="https://www.instagram.com/brewvita/?hl=en"
                        class="px-6 py-3 border-hard rounded-full bg-white hover:bg-navy hover:text-white transition-colors font-bold uppercase text-sm shadow-hard hover:shadow-hard-hover hover:translate-x-[3px] hover:translate-y-[3px]"
                        >Instagram</a
                    >
                </div>

                <div
                    class="text-sm uppercase tracking-widest text-slate"
                >
                    <p>Follow us on social media</p>
                </div>
            </div>
        </section>

        <Footer />
        <MessagesWidget />
    </body>
</html>
